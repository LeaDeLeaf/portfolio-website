# EmailJS Configuration (Get these from https://www.emailjs.com/)
# Sign up for free, create a service, template, and get your public key
# Remember: In Vite, env variables MUST start with VITE_ to be accessible

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID=your_autoreply_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
